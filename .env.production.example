# ================================================================
# .env.production.example — Template variabel environment production
#
# CARA PAKAI DI VPS:
#   cp .env.production.example .env
#   nano .env   ← isi semua nilai yang kosong
# ================================================================

# ── PostgreSQL ─────────────────────────────────────────────────────
POSTGRES_DB=porto_db
POSTGRES_USER=porto_user
POSTGRES_PASSWORD=GANTI_DENGAN_PASSWORD_AMAN_MINIMAL_20_KARAKTER

# ── Database URL (gunakan nama service docker-compose: 'postgres') ─
DATABASE_URL="postgresql://porto_user:GANTI_DENGAN_PASSWORD_AMAN_MINIMAL_20_KARAKTER@postgres:5432/porto_db?schema=public"

# ── Auth.js ────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=GANTI_DENGAN_RANDOM_STRING_MINIMAL_32_KARAKTER

# ── URL Publik Aplikasi ────────────────────────────────────────────
NEXTAUTH_URL=https://yourdomain.com
